# Backend environment for MongoDB Atlas
PORT=5000

# Paste your Atlas connection string here.
# Example format:
# mongodb+srv://<username>:<password>@<cluster>.mongodb.net/support_system?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=

# Set to false for Atlas so startup fails fast if Atlas is unreachable.
ALLOW_IN_MEMORY_DB=false

JWT_SECRET=replace-with-a-long-random-secret
JWT_RESET_SECRET=replace-with-a-long-random-secret

FRONTEND_URL=http://localhost:5173
FRONTEND_URLS=http://localhost:5173,http://localhost:3000

# Optional AI config
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_APP_NAME=Support System Backend
